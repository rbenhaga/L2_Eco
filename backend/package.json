{
  "name": "revp2-backend",
  "version": "1.0.0",
  "description": "Backend API for RevP2 - Stripe payments and subscription management",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env --import tsx server.js",
    "dev": "node --env-file=.env --watch --import tsx server.js",
    "init-db": "node --env-file=.env --import tsx scripts/init-db.js",
    "migrate": "node --env-file=.env --experimental-strip-types db/migrations/run-migration.ts",
    "test-tts": "node --env-file=.env --import tsx scripts/test-tts.js",
    "test-latex-formatting": "node --env-file=.env --import tsx scripts/test-latex-formatting.js",
    "generate-tts": "node --env-file=.env --import tsx scripts/generate-all-tts.js",
    "oiko:collect": "node --env-file=.env --experimental-strip-types scripts/oiko-run.ts --step collect",
    "oiko:compose": "node --env-file=.env --experimental-strip-types scripts/oiko-run.ts --step compose",
    "oiko:send": "node --env-file=.env --experimental-strip-types scripts/oiko-run.ts --step send",
    "oiko:run": "node --env-file=.env --experimental-strip-types scripts/oiko-run.ts --step all",
    "oiko:v3": "node --env-file=.env --experimental-strip-types scripts/oiko-run.ts --step v3",
    "oiko:dry-run": "node --env-file=.env --experimental-strip-types scripts/oiko-run.ts --step all --dry-run",
    "oiko:audit": "node --env-file=.env --experimental-strip-types scripts/oiko-audit.ts",
    "typecheck": "tsc -p tsconfig.json",
    "oiko:promote-v3": "node --env-file=.env --experimental-strip-types scripts/oiko-promote-v3.ts",
    "test:oiko:v3": "node --experimental-strip-types scripts/test-oiko-v3.ts"
  },
  "keywords": [
    "stripe",
    "subscriptions",
    "express",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fast-xml-parser": "^5.3.2",
    "firebase-admin": "^13.6.0",
    "helmet": "^7.1.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.40.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "p-limit": "^6.1.0",
    "skia-canvas": "^3.0.8",
    "stripe": "^14.10.0",
    "tsx": "^4.20.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/nodemailer": "^7.0.3",
    "typescript": "^5.9.3"
  }
}
