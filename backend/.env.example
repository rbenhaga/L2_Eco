# Environment Configuration
NODE_ENV=development

# Server
PORT=3001

# Stripe Keys (Get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
STRIPE_PRICE_ID_PASS_PARTIELS_S4=price_YOUR_PASS_PRICE_ID_HERE
STRIPE_PASS_DURATION_DAYS=30
# Legacy fallback if needed
STRIPE_PRICE_ID=price_YOUR_PRICE_ID_HERE

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_PATH=./database/subscriptions.db

# ==========================================
# AI CHATBOT CONFIGURATION
# ==========================================

# === AI PROVIDERS ===
# Groq (Primary - fast, high quota) - https://console.groq.com
GROQ_API_KEY=gsk_...

# Google Gemini (Backup) - https://ai.google.dev/
GEMINI_API_KEY=AIza...

# OpenRouter (Fallback) - https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_REFERER=https://yourdomain.com
OPENROUTER_APP_NAME=RevP2

# === EMBEDDINGS & CACHE ===
# Cloudflare Workers AI - https://dash.cloudflare.com/
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Upstash Vector - https://console.upstash.com/
UPSTASH_VECTOR_URL=https://your-vector-db.upstash.io
UPSTASH_VECTOR_TOKEN=your_vector_token

# === CONFIGURATION ===
AI_CACHE_MIN_SIMILARITY=0.88
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_RESET_TIMEOUT_MS=60000

# === FIREBASE (for authentication) ===
# Option A (recommended on VPS): full JSON service account in one env var
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Option B: file path to service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
#
# Option C: split credentials
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === SECURITY (AI API Protection) ===
# VPS Public IP (for IP whitelisting) - Find with: curl ifconfig.me
VPS_IP=YOUR_VPS_PUBLIC_IP

# Frontend URLs (for CORS + Origin verification)
FRONTEND_URL_WWW=https://www.yourdomain.com

# ==========================================
# AZURE SPEECH TTS CONFIGURATION
# ==========================================

# Azure Speech Service (for TTS generation)
# Get credentials from: https://portal.azure.com
# 1. Create a "Speech Services" resource
# 2. Go to "Keys and Endpoint"
# 3. Copy KEY 1 and LOCATION/REGION
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=francecentral

# Voice configuration
# Default voice: fr-FR-Vivienne:DragonHDLatestNeural (Neural HD)
# Cost: $16 per 1M characters (one-time generation)
AZURE_SPEECH_VOICE=fr-FR-Vivienne:DragonHDLatestNeural

# ==========================================
# OIKO NEWS CONFIGURATION
# ==========================================
OIKO_PRIMARY_PROVIDER=groq
OIKO_PRIMARY_MODEL=llama-3.3-70b-versatile
OIKO_SECONDARY_PROVIDER=
OIKO_SECONDARY_MODEL=
# IMPORTANT: in production, set this to your real public backend URL so email and archive assets do not point to localhost.
OIKO_PUBLIC_BASE_URL=http://localhost:3001
OIKO_CRON_ENABLED=false
OIKO_V3_SHADOW_ENABLED=false
OIKO_V3_PUBLIC_ENABLED=false
OIKO_FRONTEND_BASE_URL=http://localhost:5173
OIKO_TOKEN_SECRET=replace_me_with_a_long_random_secret
OIKO_MAIL_FROM=Oiko News <newsletter@example.com>
OIKO_SMTP_HOST=
OIKO_SMTP_PORT=587
OIKO_SMTP_SECURE=false
OIKO_SMTP_USER=
OIKO_SMTP_PASS=
OIKO_SENDMAIL_PATH=
THENEWS_API_TOKEN=
NEWSDATA_API_KEY=
ALPHAVANTAGE_API_KEY=
COINGECKO_API_KEY=
PIXABAY_API_KEY=
PEXELS_API_KEY=


# Wikimedia Commons read-only API does not require an API key.
# Set a descriptive user agent as recommended by MediaWiki for automated access.
WIKIMEDIA_USER_AGENT=OikoNews/1.0 (contact@clipperpro.app)

