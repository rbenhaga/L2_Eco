{
    "name": "revp2-backend",
    "version": "1.0.0",
    "description": "Backend API for RevP2 - Stripe payments and subscription management",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node --env-file=.env server.js",
        "dev": "node --env-file=.env --watch server.js",
        "init-db": "node scripts/init-db.js",
        "test-tts": "node scripts/test-tts.js",
        "test-latex-formatting": "node scripts/test-latex-formatting.js",
        "generate-tts": "node scripts/generate-all-tts.js"
    },
    "keywords": [
        "stripe",
        "subscriptions",
        "express",
        "api"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "better-sqlite3": "^9.2.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "firebase-admin": "^13.6.0",
        "helmet": "^7.1.0",
        "microsoft-cognitiveservices-speech-sdk": "^1.40.0",
        "p-limit": "^6.1.0",
        "stripe": "^14.10.0"
    }
}
