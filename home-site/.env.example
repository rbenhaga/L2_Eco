# Example .env file for frontend
# Copy to .env.local in home-site/ directory

# Backend API URL
VITE_API_URL=http://localhost:3001

# Optional: force onboarding to appear at every login for specific emails (comma-separated)
# Example: VITE_FORCE_ONBOARDING_EMAILS=test1@gmail.com,test2@gmail.com
VITE_FORCE_ONBOARDING_EMAILS=

# Firebase configuration (already configured, keep existing values)
# VITE_FIREBASE_API_KEY=...
# VITE_FIREBASE_AUTH_DOMAIN=...
# etc.

# Analytics (Google Analytics / Firebase Analytics)
VITE_ENABLE_ANALYTICS=true
VITE_ANALYTICS_DEFAULT_CONSENT=denied

# Local dev only: set to false in .env.local to disable copy/select/print restrictions
VITE_ENABLE_CONTENT_PROTECTION=true
